# --- Core infrastructure ---
APP_ENV=development
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/ragdb
DATABASE_CONNECT_TIMEOUT_SECONDS=2.0
REDIS_URL=redis://localhost:6379
INGESTION_QUEUE_PROVIDER=inline
INGESTION_QUEUE_NAME=ragresover:ingestion
INGESTION_JOB_MAX_ATTEMPTS=3
INGESTION_RETRY_DELAY_SECONDS=1.0
INGESTION_WORKER_POLL_TIMEOUT_SECONDS=5
INGESTION_STALE_JOB_TIMEOUT_SECONDS=900
DEBUG=true
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
ALLOW_ANONYMOUS_ACCESS=true
DEFAULT_TENANT_ID=anonymous
API_AUTH_TOKEN=

# --- Storage (MinIO/S3 compatible) ---
STORAGE_ENDPOINT=localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET_NAME=documents
STORAGE_SECURE=false
STORAGE_REQUIRED=false
STORAGE_CONNECT_TIMEOUT_SECONDS=1.0
STORAGE_READ_TIMEOUT_SECONDS=30.0
STORAGE_MAX_RETRIES=0

# --- LLM and embedding providers ---
# Local-first demo mode. Requires:
#   ollama pull llama3.2:3b
#   ollama pull nomic-embed-text
OPENAI_API_KEY=
LLM_PROVIDER=ollama
EMBEDDING_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=llama3.2:3b
CHAT_MAX_CONTEXT_CHARS=6000
EMBEDDING_MODEL=nomic-embed-text
EMBEDDINGS_ENABLED=true
EMBEDDINGS_REQUIRED=false
EMBEDDING_DIMENSIONS=768
TEMPERATURE=0.0

# OpenAI alternative:
# OPENAI_API_KEY=sk-...
# LLM_PROVIDER=openai
# EMBEDDING_PROVIDER=openai
# LLM_MODEL=gpt-4o
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIMENSIONS=1536

# --- RAG parameters ---
CHUNK_SIZE=500
CHUNK_OVERLAP=50
VECTOR_SEARCH_TOP_K=5
RETRIEVAL_SCORE_THRESHOLD=
RETRIEVAL_FETCH_MULTIPLIER=4
RERANKER_PROVIDER=none
MAX_UPLOAD_BYTES=10485760
ALLOWED_UPLOAD_CONTENT_TYPES=text/plain,text/markdown,application/json,application/pdf,application/vnd.openxmlformats-officedocument.wordprocessingml.document

# --- Optional future integrations ---
COHERE_API_KEY=

# --- Observability ---
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
